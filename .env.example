# .env.example
# Copy this file to .env and modify as needed

# Port configuration
BACKEND_ML_PORT=8000
BACKEND_LLM_PORT=8001
LLAMAT2_CHAT_PORT=8002
AGENTS_PORT=8003
AGENT_CORE_PORT=8004
FRONTEND_PORT=3000

# Flags
ENVIRONMENT=development
LOG_LEVEL=info

# Provider configuration
# Format: AGENT_{ROLE}_MODEL_PROVIDER=provider:model
# Examples:
# AGENT_EVALUATOR_MODEL_PROVIDER=openrouter:anthropic/claude-3-opus
# AGENT_PLANNER_MODEL_PROVIDER=ollama:deepseek-r1:8b
# AGENT_EMBEDDING_MODEL_PROVIDER=ollama:mxbai-embed-large

# Default models (legacy format - still supported)
AGENT_BASE_MODEL=deepseek-r1:8b
AGENT_PLANNING_EVALUATOR_MODEL=deepseek-r1:8b
AGENT_EVALUATOR_MODEL=deepseek-r1:8b
AGENT_PLANNER_MODEL=deepseek-r1:8b
AGENT_INSIGHTS_MODEL=deepseek-r1:8b
AGENT_FINAL_MODEL=deepseek-r1:8b
AGENT_CIF_MODEL=WilhelmBuitrago/llamat-3-cif-8b:Q5_K_M
AGENT_DOMAIN_CRITIC_MODEL=WilhelmBuitrago/llamat-3-chat-8b:Q5_K_M
AGENT_EMBEDDING_MODEL=mxbai-embed-large

# Fallback chains
# Format: AGENT_{ROLE}_FALLBACK=provider1,provider2,provider3
# Examples:
# AGENT_EVALUATOR_FALLBACK=openrouter,ollama
# AGENT_PLANNER_FALLBACK=ollama,openrouter