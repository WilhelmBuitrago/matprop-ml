#UnPayWall
UNPAYWALL_EMAIL=

# API Keys
MP_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Email configurations
CROSSREF_EMAIL=

# Service URLs
# NOTE: Model selection is owned by agents service; agent_core consumes /v2 contracts.
AGENTS_URL=http://agents:8003
AGENTS_SERVICE_URL=http://agents:8000

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:3000

# Policy mode: legacy | planned
AGENT_POLICY_MODE=legacy

# Evaluator stop threshold (0.0-1.0) for deterministic stop gating.
AGENT_EVALUATOR_STOP_TAU=0.75

# Tracing Configuration
AGENT_TRACE_DIR=agent_core/data/traces