#UnPayWall
UNPAYWALL_EMAIL=research-bot@example.com

# API Keys
MP_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Email configurations
CROSSREF_EMAIL=research-bot@example.com

# Service URLs
# NOTE: Model selection is owned by agents service; agent_core consumes /v2 contracts.
AGENTS_URL=http://agents:8003
AGENTS_SERVICE_URL=http://agents:8003

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:3000

# Security
AGENT_AUTH_MODE=disabled
AGENT_API_KEY=
AGENT_API_KEY_HEADER=X-API-Key

# Rate limiting
AGENT_RATE_LIMIT_ENABLED=true
AGENT_RATE_LIMIT_MAX_REQUESTS=10
AGENT_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO

# Entry policy configuration.
AGENT_ENTRY_TOP_K=3

# Shared planning/evaluation model configuration.
AGENT_PLANNING_EVALUATOR_MODEL=deepseek-r1:8b
AGENT_PLANNER_MODEL=deepseek-r1:8b
AGENT_EVALUATOR_MODEL=deepseek-r1:8b

# Tracing Configuration
AGENT_TRACE_DIR=agent_core/data/traces
