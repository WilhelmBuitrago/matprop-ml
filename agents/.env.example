# GPU Configuration
# Prefer GPU when available; if not detected service falls back to CPU.
AGENTS_OLLAMA_PREFER_GPU=true

# NVIDIA GPU devices visibility (leave empty for all devices)
NVIDIA_VISIBLE_DEVICES=

# Model Configuration
# Decision model for inference
AGENTS_DECISION_MODEL=yasserrmd/Qwen2.5-7B-Instruct-1M

# Model unload policy after each request.
# Use 0s to unload immediately.
AGENTS_OLLAMA_KEEP_ALIVE=0s
