# GPU Configuration
# Prefer GPU when available; if not detected service falls back to CPU.
AGENTS_OLLAMA_PREFER_GPU=true

# NVIDIA GPU devices visibility (leave empty for all devices)
NVIDIA_VISIBLE_DEVICES=

# Model Configuration (owned by agents runtime)
# These vars define model selection for all /v2 contracts consumed by agent_core.
# Model Configuration
AGENT_BASE_MODEL=deepseek-r1:8b
AGENT_PLANNING_EVALUATOR_MODEL=deepseek-r1:8b
AGENT_EVALUATOR_MODEL=deepseek-r1:8b
AGENT_INSIGHTS_MODEL=deepseek-r1:8b
AGENT_PLANNER_MODEL=deepseek-r1:8b
AGENT_FINAL_MODEL=deepseek-r1:8b
AGENT_CIF_MODEL=WilhelmBuitrago/llamat-3-cif-8b:Q5_K_M
AGENT_EMBEDDING_MODEL=mxbai-embed-large

# Model unload policy after each request.
# Use 0s to unload immediately.
AGENTS_OLLAMA_KEEP_ALIVE=0s
